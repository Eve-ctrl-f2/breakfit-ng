# Frontend build-time flags (consumed via src/environments/environment.production.ts).
# Angular's @angular/build reads these only if you wire them; by default edit
# environment.production.ts directly. Kept here as documentation of the knobs.
#
# cloudEnabled : false => local-only build (no auth, no sync, no network on boot)
# apiBase      : backend origin when cloudEnabled = true
# feedbackEmail: mailto target for the Feedback button
