PORT=8080
NODE_ENV=development
DATABASE_URL=postgres://breakfit:breakfit@localhost:5432/breakfit
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:4200

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:feedback@breakfit.app

# Reminder scheduler (local-hour window per user; minutes between ticks)
REMINDER_INTERVAL_MIN=15
REMINDER_WINDOW_START=18
REMINDER_WINDOW_END=20

# Email (passwordless login delivery)
# EMAIL_PROVIDER: console (dev, logs the code) | resend (prod, HTTP API)
EMAIL_PROVIDER=console
# Required when EMAIL_PROVIDER=resend:
RESEND_API_KEY=
EMAIL_FROM=BreakFit <login@breakfit.app>

# Observability
LOG_LEVEL=info
# If set, GET /metrics requires `Authorization: Bearer <token>` (Prometheus scrape)
METRICS_TOKEN=
